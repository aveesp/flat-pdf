// 1. Load the document into pdf-lib
const pdfDoc = await PDFDocument.load(arrayBuffer);
const context = pdfDoc.context;

try {
  const form = pdfDoc.getForm();

  // IMPORTANT: Tell pdf-lib to look at all current data values inside the 
  // form fields and draw actual, physical text vectors onto the page canvas.
  form.updateFieldAppearances();

  // Try standard flattening to lock the newly drawn text to the page
  form.flatten();
} catch (e) {
  console.warn("High-level flatten step encountered structural anomalies, handling via fallback...");
}

// 2. THE SAFE PURGE: Loop pages to drop only the interaction layer, keeping the text visuals
const pages = pdfDoc.getPages();
for (const page of pages) {
  const pageDict = page.node;
  const annotsKey = context.obj('Annots');

  if (pageDict.has(annotsKey)) {
    const annotsArray = pageDict.get(annotsKey);
    
    if (annotsArray && (annotsArray as any).array) {
      const array = (annotsArray as any).array;
      
      // Loop backwards through annotations to safely remove interactive wrappers
      for (let i = array.length - 1; i >= 0; i--) {
        const annotRef = array[i];
        const annotMap = context.lookup(annotRef);
        
        if (annotMap && typeof (annotMap as any).get === 'function') {
          const subtype = (annotMap as any).get(context.obj('Subtype'));
          
          // WE ONLY REMOVE THE WIDGET LAYER.
          // By running form.updateFieldAppearances() first, pdf-lib left the 
          // text appearances on the page, so stripping the /Widget now leaves the text intact.
          if (subtype && subtype.toString() === '/Widget') {
            array.splice(i, 1);
          }
        }
      }

      // If the page has no more annotations left, delete the key completely
      if (array.length === 0) {
        pageDict.delete(annotsKey);
      }
    }
  }
}

// 3. Final cleanup of the root form dictionary map
try {
  pdfDoc.catalog.delete(context.obj('AcroForm'));
} catch (e) {}

// 4. Save and serve the read-only file with data intact
const flattenedPdfBytes = await pdfDoc.save();
const resultBlob = new Blob([flattenedPdfBytes], { type: 'application/pdf' });

this.flattenedPdfUrl = URL.createObjectURL(resultBlob);
