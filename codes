import { PDFDocument } from 'pdf-lib';

// Inside your processing method:
const pdfDoc = await PDFDocument.load(arrayBuffer);
const context = pdfDoc.context;

try {
  const form = pdfDoc.getForm();

  // 1. WIPE THE WEB-FORM ENGINE (XFA)
  // This breaks the browser's ability to overlay active HTML inputs over the text
  try {
    form.deleteXFA();
  } catch (e) {
    console.log("No dynamic XML/XFA structure detected.");
  }

  // 2. STAMP DATA VALUES & REMOVE FIELD LOGIC
  // Loop through all fields, turn on read-only, and draw the hard text shapes
  const fields = form.getFields();
  fields.forEach(field => {
    try {
      field.enableReadOnly();
    } catch(e){}
  });

  // Force pdf-lib to bake the current typed text permanently onto the canvas vectors
  form.updateFieldAppearances();

} catch (globalFormError) {
  console.error("Form utility error:", globalFormError);
}

// 3. HARD REMOVAL OF FIELD INTERACTION INTERFACES
// This sweeps through the PDF dictionary tree and unlinks the text fields 
// from acting like form elements entirely, leaving just the text vectors behind.
const pages = pdfDoc.getPages();
for (const page of pages) {
  const pageDict = page.node;
  const annotsKey = context.obj('Annots');

  if (pageDict.has(annotsKey)) {
    const annotsArray = pageDict.get(annotsKey);
    if (annotsArray && (annotsArray as any).array) {
      const array = (annotsArray as any).array;

      for (let i = array.length - 1; i >= 0; i--) {
        const annotRef = array[i];
        const annotMap = context.lookup(annotRef);

        if (annotMap && typeof (annotMap as any).get === 'function') {
          const subtype = (annotMap as any).get(context.obj('Subtype'));
          
          if (subtype && subtype.toString() === '/Widget') {
            // Unlink interactive keys while leaving the appearance streams (/AP) untouched
            // This leaves the text fully visible but stops the browser from treating it as an input box
            (annotMap as any).delete(context.obj('FT')); // Drops field type definition
            (annotMap as any).delete(context.obj('T'));  // Drops structural field mapping
            (annotMap as any).delete(context.obj('AA')); // Drops interactive trigger actions
            
            // Set it as a flat free-text annot element rather than an input widget
            (annotMap as any).set(context.obj('Subtype'), context.obj('FreeText'));
          }
        }
      }
    }
  }
}

// Clean up global AcroForm linkages
try { pdfDoc.catalog.delete(context.obj('AcroForm')); } catch (e) {}

// 4. Save out the permanently un-editable file layout
const protectedPdfBytes = await pdfDoc.save();
const resultBlob = new Blob([protectedPdfBytes], { type: 'application/pdf' });

this.flattenedPdfUrl = URL.createObjectURL(resultBlob);
