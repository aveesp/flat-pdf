import { PDFDocument, PDFName, PDFNumber } from 'pdf-lib';

// Inside your fetch / processing method:
// 1. Load the document into pdf-lib
const pdfDoc = await PDFDocument.load(arrayBuffer);
const context = pdfDoc.context;

try {
  const form = pdfDoc.getForm();
  
  // Wipe out dynamic complex layout scripts that clash with rendering
  try { form.deleteXFA(); } catch(e){}

  // Loop through every logical form element inside the file architecture
  const fields = form.getFields();
  fields.forEach(field => {
    try {
      // Step A: Lock user entry at the conceptual programmatic level
      field.enableReadOnly();
      
      // Step B: Target the underlying PDF structural components directly
      const widgets = field.acroField.getWidgets();
      widgets.forEach(widget => {
        // We configure the structural /F (Flags) number key.
        // Value '1' implies standard visual rendering.
        // Value '64' implies Locked (prevents changes/deletion in tools).
        // Combined (1 + 64 = 65) locks the entry completely while maintaining text viability.
        widget.dict.set(PDFName.of('F'), PDFNumber.of(65));
        
        // Remove individual inner action handlers (/AA /A) that trigger dropdown/edit actions
        widget.dict.delete(PDFName.of('AA'));
        widget.dict.delete(PDFName.of('A'));
      });
    } catch (fieldError) {
      console.warn("Skipped a nested structural element context:", fieldError);
    }
  });

  // Force the layout engine to build matching vector silhouettes for the text
  form.updateFieldAppearances();
} catch (globalFormError) {
  console.error("Structural processing encountered exceptions, running page-level bypass...", globalFormError);
}

// 2. Page Level Reinforcement: Strip input capability directly out of the visual elements
const pages = pdfDoc.getPages();
for (const page of pages) {
  const pageDict = page.node;
  const annotsKey = context.obj('Annots');

  if (pageDict.has(annotsKey)) {
    const annotsArray = pageDict.get(annotsKey);
    if (annotsArray && (annotsArray as any).array) {
      const array = (annotsArray as any).array;

      for (let i = array.length - 1; i >= 0; i--) {
        const annotRef = array[i];
        const annotMap = context.lookup(annotRef);

        if (annotMap && typeof (annotMap as any).get === 'function') {
          const subtype = (annotMap as any).get(context.obj('Subtype'));
          
          if (subtype && subtype.toString() === '/Widget') {
            // Instead of deleting the /Widget completely (which hides the font),
            // we remove the specific interactive Subtype trigger /Widget entirely,
            // or we clear out the field's interactive link mappings (/FT)
            (annotMap as any).delete(context.obj('FT')); // Removes Text Form context
            (annotMap as any).delete(context.obj('T'));  // Removes internal Name link
            
            // Re-assign the element as a simple /FreeText or standard visual asset
            (annotMap as any).set(context.obj('Subtype'), context.obj('FreeText'));
          }
        }
      }
    }
  }
}

// 3. Save the modified document
const flattenedPdfBytes = await pdfDoc.save();
const resultBlob = new Blob([flattenedPdfBytes], { type: 'application/pdf' });

this.flattenedPdfUrl = URL.createObjectURL(resultBlob);
